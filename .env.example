# Brevo transactional email — https://app.brevo.com/settings/keys/api
#nanti kau register je brevo - generate api key - masukkan ke sini 
BREVO_API_KEY=

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com

# Verified Brevo sender address
CONTACT_FROM_EMAIL=noreply@example.com

# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
#turnstile ni tak perlu pun kalau kau tak nak guna captcha, 
#tapi kalau nak guna captcha kau kena register turnstile kat 
#cloudflare - generate site key & secret key - masukkan ke sini
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
